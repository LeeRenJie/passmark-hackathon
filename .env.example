# Copy to .env and fill in real values. Never commit .env.

# Required. OpenRouter API key — issued by the Breaking Apps Hackathon on
# registration, or get one at https://openrouter.ai. Routes Claude + Gemini
# through a single gateway, bypassing the free-tier rate caps that otherwise
# choke multi-model consensus runs.
OPENROUTER_API_KEY=sk-or-...

# Optional (recommended). Redis connection string for Passmark's step cache.
# Start one locally via:
#   docker run -d --name passmark-redis -p 6379:6379 redis:alpine
# Without Redis, every step hits AI on every run. With Redis, successful
# single-tool actions replay as native Playwright at millisecond speed.
REDIS_URL=redis://localhost:6379

# Optional. Set to `debug` for verbose Passmark logs.
# PASSMARK_LOG_LEVEL=debug

# --- Not used in this suite, but kept for reference ---
# If you'd rather hit provider SDKs directly (no gateway), set these and
# remove the `configure({ ai: { gateway: "openrouter" } })` call from
# playwright.config.ts. Note that Gemini's free tier is 5 RPM, which is too
# tight for a multi-spec Passmark suite.
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
